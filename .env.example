# =============================================================================
# NetSuite Requirement Gatekeeper — Environment Variables
# =============================================================================
# Copy this file to .env and fill in every value before starting the bot.
#
#   cp .env.example .env
#
# All variables marked REQUIRED must be set. The bot will refuse to start
# (validate_config) if any are missing.
# =============================================================================

# ─── Slack ───────────────────────────────────────────────────────────────────

# Bot OAuth token (starts with xoxb-). Found in your Slack app → OAuth & Permissions.
# REQUIRED
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-level token for Socket Mode (starts with xapp-).
# Found in your Slack app → Basic Information → App-Level Tokens.
# Needs the connections:write scope.
# REQUIRED
SLACK_APP_TOKEN=xapp-your-app-token-here

# Slack channel ID where escalation notifications are posted.
# Right-click the channel in Slack → Copy link — the ID is the last segment.
# REQUIRED
TRIAGE_CHANNEL_ID=C0000000000

# ─── Anthropic ───────────────────────────────────────────────────────────────

# API key from console.anthropic.com
# REQUIRED
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Jira ────────────────────────────────────────────────────────────────────

# Base URL of your Atlassian Cloud instance (no trailing slash).
# REQUIRED
JIRA_BASE_URL=https://yourorg.atlassian.net

# Jira project key where tickets are created.
# REQUIRED
JIRA_PROJECT_KEY=FIN

# Email address of the Jira service account used for API calls.
# REQUIRED
JIRA_USER_EMAIL=jira-bot@yourorg.com

# Jira API token for the service account above.
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
# REQUIRED
JIRA_API_TOKEN=your-jira-api-token-here

# Issue type ID (10001 = Story in most instances). Optional — defaults to 10001.
JIRA_ISSUE_TYPE_ID=10001

# Optional: override the ticket creation endpoint (auto-derived from JIRA_BASE_URL).
# JIRA_CREATE_ISSUE_URL=https://yourorg.atlassian.net/rest/api/3/issue

# ─── Jira Custom Fields ──────────────────────────────────────────────────────
# Find IDs via: GET /rest/api/3/field

JIRA_CF_VALUE_TO_BUSINESS=customfield_12975
JIRA_CF_ACCEPTANCE_CRITERIA=customfield_12977
JIRA_CF_ENABLEMENT_PLAN=customfield_12978

# Default field overrides (optional)
# JIRA_CF_DEFAULT_1=customfield_12004
# JIRA_CF_DEFAULT_2=customfield_10104
# JIRA_CF_DEFAULT_3=customfield_12985

# ─── Database ────────────────────────────────────────────────────────────────
# Option A: full connection string (preferred)
DATABASE_URL=postgresql://gatekeeper:your-db-password@localhost:5432/gatekeeper

# Option B: individual variables (used if DATABASE_URL is not set)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=gatekeeper
# PGUSER=gatekeeper
# PGPASSWORD=your-db-password

# Set to 1 to run init_db() (CREATE TABLE IF NOT EXISTS + migrations) on startup.
# For single-instance pilot deployments, set this to 1.
# For multi-instance deploys, leave unset and run migrations out-of-band
# to avoid concurrent ALTER TABLE deadlocks.
RUN_MIGRATIONS=1